{
  "name": "vibebook",
  "version": "0.4.1",
  "description": "Sync AI coding sessions across machines + digest into a per-project chronicle/topics/cards book via in-session Claude. Ships as both an npm CLI and a Claude Code plugin.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/june9593/vibebook.git"
  },
  "homepage": "https://github.com/june9593/vibebook",
  "bugs": "https://github.com/june9593/vibebook/issues",
  "keywords": [
    "memory",
    "ai",
    "claude",
    "copilot",
    "sessions",
    "digest",
    "vibe-coding",
    "vibebook"
  ],
  "bin": {
    "vibebook": "./dist/bin/vibebook.js"
  },
  "files": [
    "dist/",
    "assets/",
    "skills/",
    "commands/",
    "hooks/",
    ".claude-plugin/",
    "site-template/",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx bin/vibebook.ts",
    "prepack": "npm run build && chmod +x dist/bin/vibebook.js",
    "prepublishOnly": "npm test"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "simple-git": "^3.25.0",
    "chalk": "^5.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
