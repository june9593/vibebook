# Belt-and-suspenders: package.json `files` is the primary allowlist.
# Anything below is what `files` must not accidentally include.

# Editor / IDE
.claude/
.vscode/
.idea/
*.swp
*.swo

# CI / dev infra
.github/

# Internal docs / sprint planning (private)
docs/
plans/
tmp/

# Project sources (we ship dist/ instead)
src/
bin/
tests/
tsconfig.json
vitest.config.ts

# Workspace / repo plumbing
.gitignore
.npmignore
.memvc-local/

# Logs / packed tarballs
*.tgz
*.log
.DS_Store

# Site template ships as source; never ship its installed deps or build output.
site-template/node_modules/
site-template/dist/
site-template/.astro/
site-template/package-lock.json

# Marketing-site is for the project landing page only; never goes to npm.
marketing-site/

# Secrets
.env
.env.*
