---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  /** "en" or "zh". Drives <html lang>, the language switch link, and
   *  the footer credit copy. Defaults to "en" so the root index works
   *  unchanged. */
  lang?: "en" | "zh";
}
const { title, description, lang = "en" } = Astro.props;
const base = import.meta.env.BASE_URL;
const isZh = lang === "zh";

// Language switcher: each page links to its counterpart.
//   /         <-> /zh/
const otherHref = isZh ? base : `${base}zh/`;
const otherLabel = isZh ? "English" : "中文";

const navLinks = isZh
  ? { changelog: "更新日志", plugin: "Claude 插件" }
  : { changelog: "Changelog", plugin: "Claude plugin" };
---
<!doctype html>
<html lang={isZh ? "zh-Hans" : "en"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    {/* Tell search engines the alternate language. */}
    <link rel="alternate" hreflang="en" href={`${base}`} />
    <link rel="alternate" hreflang="zh" href={`${base}zh/`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,500&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400&family=Noto+Serif+SC:wght@400;500&display=swap"
    />
  </head>
  <body>
    <nav class="site-nav">
      <div class="container">
        <a class="brand" href={base}>vibebook</a>
        <div class="links">
          <a href="https://github.com/june9593/vibebook">GitHub</a>
          <a href="https://www.npmjs.com/package/vibebook">npm</a>
          <a href="https://github.com/june9593/vibebook/blob/main/CHANGELOG.md">{navLinks.changelog}</a>
          <a href="https://june9593.github.io/vibebook-plugin/">{navLinks.plugin}</a>
          <a href={otherHref} class="lang-switch" rel="alternate" hreflang={isZh ? "en" : "zh"}>{otherLabel}</a>
        </div>
      </div>
    </nav>
    <slot />
    <footer class="site-footer">
      <div class="container">
        <p class="muted small">
          {isZh ? "MIT 许可证 · 由 " : "MIT licensed · Built by "}
          <a href="https://github.com/june9593">@june9593</a>
          {isZh ? " 构建 · 与可选的 " : " · Sibling to the optional "}
          <a href="https://github.com/june9593/vibebook-plugin">vibebook-plugin</a>
          {isZh ? " Claude Code 插件互为兄弟项目。" : " Claude Code plugin."}
        </p>
      </div>
    </footer>
  </body>
</html>
