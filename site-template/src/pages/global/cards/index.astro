---
import Base from "../../../layouts/Base.astro";
import { listCards } from "../../../lib/content";

const base = import.meta.env.BASE_URL;
const cards = listCards().filter((c) => c.project === "_global");
---
<Base title="Global cards · vibebook">
  <section class="container">
    <h1 style="font-size: 2.4rem; margin-bottom: var(--space-3);">Global cards</h1>
    <p class="meta" style="margin-bottom: var(--space-10);">
      Cross-project insights: tools / languages / OS / generic best practices.
      {cards.length} card{cards.length === 1 ? "" : "s"} total.
    </p>
    <ul class="entry-list">
      {cards.map((c) => (
        <li>
          <a class="title" href={`${base}global/cards/${c.cardSlug}/`}>{c.displayTitle}</a>
          <div class="row-meta">
            <span class={`chip ${c.type}`}>{c.type}</span>
            <span class="dot">·</span>
            <span>{c.updatedAt.slice(0, 10)}</span>
            {c.tags.slice(0, 3).map((t) => (
              <>
                <span class="dot">·</span>
                <span>#{t}</span>
              </>
            ))}
          </div>
        </li>
      ))}
    </ul>
  </section>
</Base>
