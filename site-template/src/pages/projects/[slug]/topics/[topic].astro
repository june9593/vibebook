---
import Base from "../../../../layouts/Base.astro";
import { listTopics, rewriteMarkdownLinks } from "../../../../lib/content";
import { marked } from "marked";

export function getStaticPaths() {
  return listTopics().map((t) => ({
    params: { slug: t.project, topic: t.topicSlug },
    props: { topic: t },
  }));
}

const { topic } = Astro.props;
const base = import.meta.env.BASE_URL;
const md = rewriteMarkdownLinks(topic.markdown, topic.path, base);
const html = await marked.parse(md);
---
<Base title={`${topic.displayTitle} · ${topic.project} · vibebook`}>
  <article class="reading">
    <p class="meta">
      <a href={`${base}projects/${topic.project}/`} style="color: var(--olive-gray); border: none;">
        ← {topic.project}
      </a>
    </p>
    <h1 style="font-size: 2.6rem; line-height: 1.2; margin-bottom: var(--space-3);">
      {topic.displayTitle}
    </h1>
    <div class="article-meta">
      <span class="chip">topic</span>
      <span class="dot">·</span>
      <span>updated {topic.updatedAt.slice(0, 10)}</span>
      <span class="dot">·</span>
      <span>{topic.contributingThreads.length} contributing threads</span>
    </div>

    <div class="article-body" set:html={html}></div>
  </article>
</Base>
