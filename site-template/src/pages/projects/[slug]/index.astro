---
import Base from "../../../layouts/Base.astro";
import {
  listProjects,
  chroniclesFor,
  topicsFor,
  cardsFor,
  chronicleRouteSlug,
} from "../../../lib/content";

export function getStaticPaths() {
  return listProjects()
    .filter((p) => p.slug !== "_global")
    .map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params as { slug: string };
const base = import.meta.env.BASE_URL;
const chronicles = chroniclesFor(slug);
const topics = topicsFor(slug);
const cards = cardsFor(slug);
const lastTouched = [...chronicles, ...topics, ...cards]
  .map((x) => x.updatedAt)
  .sort()
  .pop();
---
<Base title={`${slug} · vibebook`}>
  <section class="container" style="margin-bottom: var(--space-12);">
    <p class="meta">
      <a href={`${base}projects/`} style="color: var(--olive-gray); border: none;">← Projects</a>
    </p>
    <h1 style="font-size: 2.8rem; margin-bottom: var(--space-3);">{slug}</h1>
    <p class="meta" style="margin: 0;">
      {chronicles.length} chronicle · {topics.length} topic · {cards.length} card
      {lastTouched && <> · last touched {lastTouched.slice(0, 10)}</>}
    </p>
  </section>

  {topics.length > 0 && (
    <section class="container" style="margin-bottom: var(--space-12);">
      <h2 style="font-size: 1.6rem; margin-bottom: var(--space-5);">Topics</h2>
      <ul class="entry-list">
        {topics.map((t) => (
          <li>
            <a class="title" href={`${base}projects/${slug}/topics/${t.topicSlug}/`}>{t.displayTitle}</a>
            <div class="row-meta">
              <span>{t.contributingThreads.length} threads</span>
              <span class="dot">·</span>
              <span>updated {t.updatedAt.slice(0, 10)}</span>
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}

  {chronicles.length > 0 && (
    <section class="container" style="margin-bottom: var(--space-12);">
      <h2 style="font-size: 1.6rem; margin-bottom: var(--space-5);">Chronicles</h2>
      <ul class="entry-list">
        {chronicles.map((c) => (
          <li>
            <a class="title" href={`${base}projects/${slug}/chronicle/${chronicleRouteSlug(c)}/`}>
              {c.displayTitle}
            </a>
            <div class="row-meta">
              <span>{c.updatedAt.slice(0, 10)}</span>
              {c.tags.slice(0, 3).map((t) => (
                <>
                  <span class="dot">·</span>
                  <span>#{t}</span>
                </>
              ))}
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}

  {cards.length > 0 && (
    <section class="container" style="margin-bottom: var(--space-12);">
      <h2 style="font-size: 1.6rem; margin-bottom: var(--space-5);">Cards</h2>
      <ul class="entry-list">
        {cards.map((c) => (
          <li>
            <a class="title" href={`${base}projects/${slug}/cards/${c.cardSlug}/`}>{c.displayTitle}</a>
            <div class="row-meta">
              <span class={`chip ${c.type}`}>{c.type}</span>
              {c.tags.slice(0, 3).map((t) => (
                <>
                  <span class="dot">·</span>
                  <span>#{t}</span>
                </>
              ))}
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}
</Base>
