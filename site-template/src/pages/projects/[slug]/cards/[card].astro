---
import Base from "../../../../layouts/Base.astro";
import { listCards, rewriteMarkdownLinks } from "../../../../lib/content";
import { marked } from "marked";

export function getStaticPaths() {
  return listCards()
    .filter((c) => c.project !== "_global")
    .map((c) => ({
      params: { slug: c.project, card: c.cardSlug },
      props: { card: c },
    }));
}

const { card } = Astro.props;
const base = import.meta.env.BASE_URL;
const md = rewriteMarkdownLinks(card.markdown, card.path, base);
const html = await marked.parse(md);
---
<Base title={`${card.displayTitle} · ${card.project} · vibebook`}>
  <article class="reading">
    <p class="meta">
      <a href={`${base}projects/${card.project}/`} style="color: var(--olive-gray); border: none;">
        ← {card.project}
      </a>
    </p>
    <h1 style="font-size: 2.2rem; line-height: 1.2; margin-bottom: var(--space-3);">
      {card.displayTitle}
    </h1>
    <div class="article-meta">
      <span class={`chip ${card.type}`}>{card.type}</span>
      <span class="dot">·</span>
      <span>{card.updatedAt.slice(0, 10)}</span>
      {card.tags.slice(0, 5).map((t) => (
        <>
          <span class="dot">·</span>
          <span>#{t}</span>
        </>
      ))}
    </div>

    <div class="article-body" set:html={html}></div>
  </article>
</Base>
