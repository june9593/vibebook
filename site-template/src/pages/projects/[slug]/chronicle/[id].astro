---
import Base from "../../../../layouts/Base.astro";
import {
  listChronicles,
  chronicleRouteSlug,
  rewriteMarkdownLinks,
} from "../../../../lib/content";
import { marked } from "marked";

export function getStaticPaths() {
  return listChronicles().map((c) => ({
    params: { slug: c.project, id: chronicleRouteSlug(c) },
    props: { chronicle: c },
  }));
}

const { chronicle } = Astro.props;
const base = import.meta.env.BASE_URL;
const md = rewriteMarkdownLinks(chronicle.markdown, chronicle.path, base);
const html = await marked.parse(md);
---
<Base title={`${chronicle.displayTitle} · ${chronicle.project} · vibebook`}>
  <article class="reading">
    <p class="meta">
      <a href={`${base}projects/${chronicle.project}/`} style="color: var(--olive-gray); border: none;">
        ← {chronicle.project}
      </a>
    </p>
    <h1 style="font-size: 2.6rem; line-height: 1.2; margin-bottom: var(--space-3);">
      {chronicle.displayTitle}
    </h1>
    <div class="article-meta">
      <span class="chip">chronicle</span>
      <span class="dot">·</span>
      <span>{chronicle.updatedAt.slice(0, 10)}</span>
      {chronicle.sessionIds.length > 0 && (
        <>
          <span class="dot">·</span>
          <span>{chronicle.sessionIds.length} session{chronicle.sessionIds.length === 1 ? "" : "s"}</span>
        </>
      )}
      {chronicle.tags.slice(0, 5).map((t) => (
        <>
          <span class="dot">·</span>
          <span>#{t}</span>
        </>
      ))}
    </div>

    <div class="article-body" set:html={html}></div>
  </article>
</Base>
